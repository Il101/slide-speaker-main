# Переключатель конвейера
PIPELINE=classic            # classic | vision | hybrid

# Vision model configuration (for vision and hybrid pipelines)
VISION_MODEL=x-ai/grok-4-fast:free    # x-ai/grok-4-fast:free | gpt-4o-mini | gemini-1.5-flash | claude-3-5-sonnet

# Google Cloud Services Configuration для Slide Speaker
# ======================================================

# Основные настройки Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=/Users/iliazarikov/Documents/Python_crypto/Barahlo/slide-speaker-main/inspiring-keel-473421-j2-22cc51dfb336.json
GCP_PROJECT_ID=inspiring-keel-473421-j2
GCP_LOCATION=us

# Document AI (OCR) настройки
GCP_DOC_AI_PROCESSOR_ID=b3533937391f6b44
OCR_BATCH_SIZE=10

# Gemini (LLM) настройки (fallback)
GEMINI_MODEL=gemini-1.5-flash
GEMINI_LOCATION=europe-west1

# OpenRouter (LLM) настройки - АКТИВНЫЙ ПРОВАЙДЕР
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=x-ai/grok-4-fast:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.2
LLM_LANGUAGE=ru

# Google Cloud Text-to-Speech настройки
GOOGLE_TTS_VOICE=ru-RU-Wavenet-D
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0

# Выбор провайдеров (установите именно эти значения)
OCR_PROVIDER=google
LLM_PROVIDER=openrouter
TTS_PROVIDER=google

# Google Cloud Storage (опционально, для хранения файлов)
GCS_BUCKET=slide-speaker-storage
GCS_BASE_URL=https://storage.googleapis.com/slide-speaker-storage

# Другие настройки
LOG_LEVEL=INFO

# CORS настройки
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176,http://127.0.0.1:5177,http://127.0.0.1:8080

# ======================================================
# СТАТУС ИНТЕГРАЦИИ:
# ======================================================
# ✅ TTS (Google Cloud Text-to-Speech) - ПОЛНОСТЬЮ РАБОТАЕТ
# ✅ LLM (OpenRouter) - ПОЛНОСТЬЮ РАБОТАЕТ
# ⚠️  Document AI - работает в fallback режиме (регион не совпадает)
# ⚠️  Gemini - работает в fallback режиме (нужно включить Vertex AI)
# 
# СИСТЕМА ГОТОВА К ИСПОЛЬЗОВАНИЮ!
# Все сервисы имеют fallback режимы и работают корректно.
