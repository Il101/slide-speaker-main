import json
import random
import time
from pathlib import Path
from typing import Optional

from locust import HttpUser, task, between, SequentialTaskSet, TaskSet
from locust.contrib.fasthttp import FastHttpUser


class AuthenticatedUser:
    """Mixin for authenticated user behavior"""
    
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self.token: Optional[str] = None
        self.lesson_id: Optional[str] = None
        self.user_id: Optional[str] = None
        # Generate unique email for this user instance
        self.email = f"loadtest_{random.randint(1, 100000)}_{int(time.time() * 1000)}@example.com"
    
    def on_start(self):
        """Register or login before starting tasks"""
        self.register_or_login()
    
    def register_or_login(self):
        """Try to register first (most common scenario), fallback to login if user exists"""
        # First, try to register (simulates new user signup)
        response = self.client.post("/api/auth/register", json={
            "email": self.email,
            "password": "TestPassword123!",
            "name": f"Load Test User"
        }, name="[Auth] Register", catch_response=True)
        
        if response.status_code == 201:
            # Registration successful, now login to get token
            response.success()
            self.login()
        elif response.status_code == 400 or response.status_code == 409:
            # User already exists, try to login
            response.success()  # Mark as success since it's expected
            self.login()
        else:
            # Unexpected error
            response.failure(f"Registration failed with status {response.status_code}: {response.text}")
    
    def login(self):
        """Login to get access token"""
        with self.client.post("/api/auth/login", 
            json={
                "email": self.email,
                "password": "TestPassword123!"
            },
            headers={
                "Origin": "http://localhost:3000"  # Required for cross-origin to get token in response
            },
            name="[Auth] Login", 
            catch_response=True
        ) as response:
            
            if response.status_code == 200:
                data = response.json()
                self.token = data.get("access_token")
                if self.token:
                    # Also get user_id if available
                    user_data = data.get("user", {})
                    response.success()
                else:
                    response.failure("No access_token in response")
            else:
                response.failure(f"Login failed with status {response.status_code}")
    
    @property
    def headers(self):
        """Return auth headers"""
        if self.token:
            return {"Authorization": f"Bearer {self.token}"}
        return {}


class HealthCheckUser(HttpUser):
    """Users that only check health endpoints (simulating monitoring systems)"""
    
    weight = 1
    wait_time = between(5, 10)
    
    @task(5)
    def health_check(self):
        """Basic health check"""
        self.client.get("/health", name="[Health] Basic")
    
    @task(2)
    def health_detailed(self):
        """Detailed health check"""
        self.client.get("/health/detailed", name="[Health] Detailed")
    
    @task(1)
    def readiness_check(self):
        """Readiness probe"""
        self.client.get("/health/ready", name="[Health] Ready")
    
    @task(1)
    def liveness_check(self):
        """Liveness probe"""
        self.client.get("/health/live", name="[Health] Live")


class BrowsingUser(AuthenticatedUser, HttpUser):
    """Users browsing lessons and content without heavy operations"""
    
    weight = 5
    wait_time = between(2, 5)
    
    @task(3)
    def list_lessons(self):
        """List user's lessons"""
        self.client.get(
            "/api/lessons/my-videos",
            headers=self.headers,
            name="[Browse] List Lessons"
        )
    
    @task(2)
    def get_lesson_status(self):
        """Check lesson status"""
        if self.lesson_id:
            self.client.get(
                f"/lessons/{self.lesson_id}/status",
                headers=self.headers,
                name="[Browse] Lesson Status"
            )
    
    @task(2)
    def get_playlists(self):
        """Get user's playlists"""
        self.client.get(
            "/api/playlists",
            headers=self.headers,
            name="[Browse] Playlists"
        )
    
    @task(1)
    def get_analytics(self):
        """View analytics dashboard"""
        self.client.get(
            "/api/analytics/admin/dashboard",
            headers=self.headers,
            name="[Browse] Analytics"
        )
    
    @task(1)
    def check_subscription(self):
        """Check subscription status"""
        self.client.get(
            "/api/subscription/info",
            headers=self.headers,
            name="[Browse] Subscription"
        )


class ContentCreatorUser(AuthenticatedUser, HttpUser):
    """Users uploading and processing presentations"""
    
    weight = 3
    wait_time = between(10, 30)
    
    @task(1)
    def upload_and_process(self):
        """Complete workflow: upload -> generate notes -> generate audio -> export"""
        
        # Step 1: Upload a test presentation
        test_file_content = b"Mock PPTX content for load testing"
        files = {
            'file': ('test_presentation.pptx', test_file_content, 'application/vnd.openxmlformats-officedocument.presentationml.presentation')
        }
        
        upload_response = self.client.post(
            "/upload",
            files=files,
            headers=self.headers,
            name="[Creator] Upload File"
        )
        
        if upload_response.status_code != 200:
            return
        
        data = upload_response.json()
        lesson_id = data.get("lesson_id")
        self.lesson_id = lesson_id
        
        # Step 2: Wait for processing
        for _ in range(10):  # Poll up to 10 times
            time.sleep(2)
            status_response = self.client.get(
                f"/lessons/{lesson_id}/status",
                headers=self.headers,
                name="[Creator] Poll Status"
            )
            
            if status_response.status_code == 200:
                status_data = status_response.json()
                if status_data.get("status") == "ready":
                    break
        
        # Step 3: Generate speaker notes
        notes_response = self.client.post(
            f"/lessons/{lesson_id}/generate-speaker-notes",
            json={
                "language": "en",
                "style": "professional",
                "length": "medium"
            },
            headers=self.headers,
            name="[Creator] Generate Notes"
        )
        
        if notes_response.status_code != 200:
            return
        
        # Step 4: Generate audio
        audio_response = self.client.post(
            f"/lessons/{lesson_id}/generate-audio",
            json={
                "voice_id": "default",
                "language": "en"
            },
            headers=self.headers,
            name="[Creator] Generate Audio"
        )


class QuizCreatorUser(AuthenticatedUser, HttpUser):
    """Users creating and managing quizzes"""
    
    weight = 2
    wait_time = between(15, 30)
    
    @task(1)
    def create_quiz(self):
        """Generate a quiz from lesson"""
        if not self.lesson_id:
            # Get a random lesson first
            response = self.client.get(
                "/api/lessons/my-videos",
                headers=self.headers,
                name="[Quiz] Get Lessons"
            )
            
            if response.status_code == 200:
                lessons = response.json()
                if lessons:
                    self.lesson_id = lessons[0].get("id")
        
        if self.lesson_id:
            self.client.post(
                f"/api/quizzes/generate",
                json={
                    "lesson_id": self.lesson_id,
                    "num_questions": 5,
                    "difficulty": "medium",
                    "question_types": ["multiple_choice"]
                },
                headers=self.headers,
                name="[Quiz] Generate"
            )
    
    @task(2)
    def list_quizzes(self):
        """List user's quizzes"""
        if self.lesson_id:
            self.client.get(
                f"/api/quizzes/lesson/{self.lesson_id}",
                headers=self.headers,
                name="[Quiz] List"
            )


class VideoExportUser(AuthenticatedUser, HttpUser):
    """Users exporting videos (resource-intensive operations)"""
    
    weight = 1  # Lower weight as this is expensive
    wait_time = between(30, 60)
    
    @task(1)
    def export_video(self):
        """Export lesson to video"""
        if not self.lesson_id:
            # Get a random lesson first
            response = self.client.get(
                "/api/lessons/my-videos",
                headers=self.headers,
                name="[Export] Get Lessons"
            )
            
            if response.status_code == 200:
                lessons = response.json()
                if lessons:
                    self.lesson_id = lessons[0].get("id")
        
        if self.lesson_id:
            export_response = self.client.post(
                f"/lessons/{self.lesson_id}/export",
                json={
                    "format": "mp4",
                    "quality": "medium",
                    "include_subtitles": True
                },
                headers=self.headers,
                name="[Export] Start Export"
            )
            
            if export_response.status_code == 200:
                # Poll export status
                for _ in range(20):
                    time.sleep(5)
                    status_response = self.client.get(
                        f"/lessons/{self.lesson_id}/export/status",
                        headers=self.headers,
                        name="[Export] Poll Status"
                    )
                    
                    if status_response.status_code == 200:
                        status_data = status_response.json()
                        if status_data.get("status") in ["completed", "failed"]:
                            break


