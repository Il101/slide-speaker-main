# Sequential workflow for realistic user journey
class UserJourneyTaskSet(SequentialTaskSet):
    """Realistic user journey from registration to video creation"""
    
    def on_start(self):
        """Setup user"""
        self.token = None
        self.lesson_id = None
        # Generate unique email with timestamp
        self.email = f"journey_{random.randint(1, 100000)}_{int(time.time() * 1000)}@example.com"
    
    @task
    def register_or_login(self):
        """Step 1: Register or login"""
        
        # Try to register first (simulates new user)
        response = self.client.post("/api/auth/register", json={
            "email": self.email,
            "password": "Journey123!",
            "name": "Journey User"
        }, name="[Journey] Register", catch_response=True)
        
        # Add Origin header for cross-origin requests (to get token in response)
        headers = {"Origin": "http://localhost:3000"}
        
        if response.status_code == 201:
            # Registration successful, now login to get token
            response.success()
            login_response = self.client.post("/api/auth/login", json={
                "email": self.email,
                "password": "Journey123!"
            }, headers=headers, name="[Journey] Login")
            
            if login_response.status_code == 200:
                self.token = login_response.json().get("access_token")
        elif response.status_code == 400 or response.status_code == 409:
            # User exists, try login
            response.success()  # Expected behavior
            login_response = self.client.post("/api/auth/login", json={
                "email": self.email,
                "password": "Journey123!"
            }, headers=headers, name="[Journey] Login")
            
            if login_response.status_code == 200:
                self.token = login_response.json().get("access_token")
    
    @task
    def upload_presentation(self):
        """Step 2: Upload a presentation"""
        if not self.token:
            return
        
        files = {
            'file': ('journey_presentation.pptx', b"Mock PPTX", 'application/vnd.openxmlformats-officedocument.presentationml.presentation')
        }
        
        response = self.client.post(
            "/upload",
            files=files,
            headers={"Authorization": f"Bearer {self.token}"},
            name="[Journey] Upload"
        )
        
        if response.status_code == 200:
            self.lesson_id = response.json().get("lesson_id")
    
    @task
    def wait_for_processing(self):
        """Step 3: Wait for processing to complete"""
        if not self.lesson_id or not self.token:
            return
        
        for _ in range(10):
            time.sleep(2)
            response = self.client.get(
                f"/lessons/{self.lesson_id}/status",
                headers={"Authorization": f"Bearer {self.token}"},
                name="[Journey] Status"
            )
            
            if response.status_code == 200:
                if response.json().get("status") == "ready":
                    break
    
    @task
    def generate_content(self):
        """Step 4: Generate speaker notes and audio"""
        if not self.lesson_id or not self.token:
            return
        
        headers = {"Authorization": f"Bearer {self.token}"}
        
        # Generate notes
        self.client.post(
            f"/lessons/{self.lesson_id}/generate-speaker-notes",
            json={"language": "en", "style": "professional"},
            headers=headers,
            name="[Journey] Generate Notes"
        )
        
        time.sleep(5)
        
        # Generate audio
        self.client.post(
            f"/lessons/{self.lesson_id}/generate-audio",
            json={"voice_id": "default"},
            headers=headers,
            name="[Journey] Generate Audio"
        )
    
    @task
    def browse_content(self):
        """Step 5: Browse lessons and analytics"""
        if not self.token:
            return
        
        headers = {"Authorization": f"Bearer {self.token}"}
        
        self.client.get(
            "/api/user-videos",
            headers=headers,
            name="[Journey] Browse"
        )
        
        time.sleep(2)
        
        self.client.get(
            "/api/analytics/dashboard",
            headers=headers,
            name="[Journey] Analytics"
        )


class RealisticUser(AuthenticatedUser, HttpUser):
    """User with realistic behavior pattern"""
    tasks = [UserJourneyTaskSet]
    weight = 2
    wait_time = between(5, 15)
