# === Core Application Settings ===
API_TITLE=Slide Speaker API
API_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8000

# === CORS Configuration ===
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000", "http://127.0.0.1:5173"]

# === Data Storage ===
DATA_DIR=.data
UPLOAD_DIR=.data/uploads
ASSETS_DIR=.data/assets
EXPORTS_DIR=.data/exports

# === File Processing ===
MAX_FILE_SIZE=104857600  # 100MB
ALLOWED_EXTENSIONS=['.pptx', '.pdf']

# === Queue Configuration ===
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === Video Export ===
FFMPEG_PATH=ffmpeg
VIDEO_QUALITY=high
MAX_EXPORT_SIZE_MB=500
EXPORT_RETRY_ATTEMPTS=3
EXPORT_TIMEOUT_SECONDS=1800

# === S3 Storage (MinIO) ===
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=slide-speaker
S3_ENDPOINT_URL=http://minio:9000

# === Google Cloud auth & project ===
GOOGLE_APPLICATION_CREDENTIALS=/app/keys/gcp-sa.json
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1

# === OCR provider ===
OCR_PROVIDER=google    # google|easyocr|paddle
GCP_DOC_AI_PROCESSOR_ID=xxxxxxxxxxxxxxxx  # Document AI processor (OCR/Layout/Tables)
OCR_BATCH_SIZE=10

# === LLM provider ===
LLM_PROVIDER=gemini    # gemini|openai|ollama|anthropic
GEMINI_MODEL=gemini-1.5-flash  # дешёвый и быстрый по умолчанию
GEMINI_LOCATION=us-central1
LLM_TEMPERATURE=0.2

# === TTS provider ===
TTS_PROVIDER=google    # google|azure|mock
GOOGLE_TTS_VOICE=ru-RU-Neural2-B
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0

# === Storage ===
STORAGE=minio          # gcs|minio
GCS_BUCKET=slide-speaker
GCS_BASE_URL=https://storage.googleapis.com/slide-speaker

# === Legacy AI Services (Sprint 2) ===
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
TTS_SERVICE=openai  # openai, elevenlabs, azure

# === Azure TTS (Legacy) ===
AZURE_TTS_KEY=your-azure-key
AZURE_TTS_REGION=your-azure-region
TTS_VOICE=ru-RU-SvetlanaNeural
TTS_SPEED=1.0