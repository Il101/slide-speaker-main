# Analytics Configuration
# Copy this to .env and fill in the values

# API URL for analytics (frontend)
VITE_API_URL=http://localhost:8000/api

# Analytics settings (optional)
ANALYTICS_ENABLED=true
ANALYTICS_BATCH_SIZE=10
ANALYTICS_BATCH_INTERVAL=5000  # ms

# Cost tracking (backend)
# These are default values in cost_tracker.py, override if needed
COST_OCR_PER_1K=1.50
COST_AI_GEMINI_FLASH_INPUT=0.15  # per 1M tokens
COST_AI_GEMINI_FLASH_OUTPUT=0.60  # per 1M tokens
COST_TTS_STANDARD=4.00  # per 1M chars
COST_TTS_NEURAL=16.00  # per 1M chars
COST_STORAGE_GB_MONTH=0.020

# Data retention (optional - implement in future)
ANALYTICS_RETENTION_DAYS=365
COST_LOGS_RETENTION_DAYS=730

# Privacy settings (optional)
ANALYTICS_IP_ANONYMIZATION=false  # Set to true for GDPR compliance
ANALYTICS_ALLOW_OPT_OUT=false  # Allow users to opt out
