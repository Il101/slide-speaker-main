# Backend Environment Variables for Docker
# Google Cloud Configuration
GOOGLE_APPLICATION_CREDENTIALS=/app/keys/gcp-sa.json
GCP_PROJECT_ID=inspiring-keel-473421-j2
GCP_LOCATION=us
GCP_DOC_AI_PROCESSOR_ID=b3533937391f6b44
OCR_BATCH_SIZE=10

# OpenRouter Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=x-ai/grok-4-fast:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_TEMPERATURE=0.2

# Gemini Configuration (fallback)
GEMINI_MODEL=gemini-1.5-flash
GEMINI_LOCATION=europe-west1

# Google Cloud Text-to-Speech Configuration (женский голос)
GOOGLE_TTS_VOICE=ru-RU-Wavenet-D
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0

# Provider Configuration
OCR_PROVIDER=google
LLM_PROVIDER=openrouter
TTS_PROVIDER=google
STORAGE=gcs

# Google Cloud Storage Configuration
GCS_BUCKET=slide-speaker-storage
GCS_BASE_URL=https://storage.googleapis.com/slide-speaker-storage

# Redis Configuration
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# MinIO Configuration (fallback storage)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=slide-speaker

# Application Configuration
PYTHONPATH=/app
DEBUG=True
LOG_LEVEL=INFO
